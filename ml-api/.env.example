# CineFlow Backend Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Choose your LLM provider: huggingface, replicate, openai, ollama
LLM_PROVIDER=huggingface

# Model to use (depends on provider)
# Hugging Face examples:
#   - microsoft/Phi-3-mini-4k-instruct (recommended, free)
#   - google/gemma-2b-it (fast, free)
#   - mistralai/Mistral-7B-Instruct-v0.2 (high quality)
#   - your-username/your-fine-tuned-model (your custom model)
#
# OpenAI examples:
#   - gpt-3.5-turbo
#   - gpt-4
#
# Replicate examples:
#   - meta/llama-2-7b-chat
#   - mistralai/mistral-7b-instruct-v0.1
#
# Ollama (local) examples:
#   - llama3.2:3b
#   - mistral
LLM_MODEL=microsoft/Phi-3-mini-4k-instruct

# =============================================================================
# API Tokens (get from provider websites)
# =============================================================================

# Hugging Face: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here

# Replicate: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_token_here

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_key_here

# =============================================================================
# Optional: Dedicated Inference Endpoint (for production)
# =============================================================================

# If using Hugging Face Inference Endpoints (paid, faster, no cold starts)
# HF_ENDPOINT_URL=https://your-endpoint.huggingface.cloud

# =============================================================================
# Server Configuration
# =============================================================================

# API port
PORT=8000

# Environment (development, production)
ENVIRONMENT=development

# Enable debug mode
DEBUG=true
